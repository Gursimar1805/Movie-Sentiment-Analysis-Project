        "id": "ovIvZQyyBQA2"
      },
      "source": [
        "Now we can see all review are in the form of a list that do not contain stopwords,are lowercase,no htmltags and no special characters"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "6RXjPxT2_cZJ"
      },
      "outputs": [],
      "source": [
        "# Perform stemming\n",
        "from nltk.stem.porter import PorterStemmer\n",
        "ps = PorterStemmer()"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "CY8QrS-MXa35"
      },
      "outputs": [],
      "source": [
        "y=[]\n",
        "def stem_words(text):\n",
        "  for i in text:\n",
        "    y.append(ps.stem(i))\n",
        "  z=y[:]\n",
        "  y.clear()\n",
        "  return z\n",
        "  # It basically stem all the words like converts loving,loved into love(Basic form)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "5k4C-QB8dWDS"
      },
      "outputs": [],
      "source": [
        "df['review'] = df['review'].apply(stem_words)"
      ]
    },
